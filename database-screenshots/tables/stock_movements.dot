digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  label="shalukhina — stock_movements";
  labelloc=t;
  "stock_movements" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>stock_movements</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">type</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">item_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → supply_items.id</TD></TR><TR><TD ALIGN="LEFT">quantity</TD><TD ALIGN="LEFT">numeric(14,3)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">happened_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">source_document</TD><TD ALIGN="LEFT">character varying(128)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">actor_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">request_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → supply_requests.id</TD></TR><TR><TD ALIGN="LEFT">comment</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
}