digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  label="shalukhina — supply_items";
  labelloc=t;
  "supply_items" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>supply_items</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(128)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">sku</TD><TD ALIGN="LEFT">character varying(64)</TD><TD ALIGN="LEFT">UNIQUE</TD></TR><TR><TD ALIGN="LEFT">category_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → supply_categories.id</TD></TR><TR><TD ALIGN="LEFT">unit</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">current_quantity</TD><TD ALIGN="LEFT">numeric(14,3)</TD><TD ALIGN="LEFT">DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">min_quantity</TD><TD ALIGN="LEFT">numeric(14,3)</TD><TD ALIGN="LEFT">DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">storage_location</TD><TD ALIGN="LEFT">character varying(128)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
}