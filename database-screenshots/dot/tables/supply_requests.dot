digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  "supply_requests" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>supply_requests</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">request_number</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">requester_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">department_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → departments.id</TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">priority</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">comment</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">approved_by_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">approved_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">rejection_reason</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
}